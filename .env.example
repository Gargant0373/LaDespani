VITE_CAPTCHA_SITE_KEY=your_recaptcha_site_key
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_TEMPLATE_ID=your_emailjs_template_id
VITE_EMAILJS_USER_ID=your_emailjs_user_id
# Optional: EmailJS template used to send a booking confirmation email to the
# guest. Set the template's "To email" field to {{email}} in the EmailJS
# dashboard. If unset, no confirmation email is sent (the on-page confirmation
# is still shown).
VITE_EMAILJS_CONFIRMATION_TEMPLATE_ID=your_emailjs_confirmation_template_id
